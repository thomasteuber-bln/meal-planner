# Copy this file to `.env.local` and fill in your key.
# `.env.local` is gitignored, so your secret stays out of version control.

# --- OpenAI (default in this project) ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Anthropic (optional alternative, see README) ---
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
