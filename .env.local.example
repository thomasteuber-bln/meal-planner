# Copy this file to `.env.local` and fill in your keys.
# `.env.local` is gitignored, so your secrets stay out of version control.

# --- OpenAI (required for the chat agent) ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Spoonacular (required for live recipe search) ---
# Sign up at https://spoonacular.com/food-api/console and paste your API key here.
SPOONACULAR_API_KEY=your-spoonacular-api-key-here

# --- Anthropic (optional alternative, see README) ---
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
